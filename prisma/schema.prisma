// WiseCard — Prisma schema
// Multi-tenant root: Organization → Users, Contacts, Cases, Tasks, Activities.
// Auth.js adapter models included for future OAuth.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ---------------------------------------------------------------------------
// Tenancy & auth
// ---------------------------------------------------------------------------

model Organization {
  id        String   @id @default(cuid())
  name      String
  slug      String   @unique
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  users      User[]
  contacts   Contact[]
  cases      Case[]
  tasks      Task[]
  activities Activity[]
  scenarios  Scenario[]
}

enum Role {
  PRINCIPAL
  ADVISOR
  ASSISTANT
}

model User {
  id            String    @id @default(cuid())
  email         String    @unique
  name          String?
  passwordHash  String?
  emailVerified DateTime?
  image         String?
  role          Role      @default(ADVISOR)

  organizationId String?
  organization   Organization? @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  accounts   Account[]
  sessions   Session[]
  tasks      Task[]     @relation("TaskAssignee")
  activities Activity[] @relation("ActivityAuthor")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([organizationId])
}

// Auth.js adapter models (used when Google/OAuth is added later)
model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

// ---------------------------------------------------------------------------
// CRM
// ---------------------------------------------------------------------------

enum ContactType {
  LEAD
  CLIENT
}

enum CaseStatus {
  NEW
  IN_PROGRESS
  SUBMITTED
  APPROVED
  CLOSED
  LOST
}

enum CasePurpose {
  PURCHASE
  REFINANCE
  EQUITY
  OTHER
}

enum ActivityChannel {
  NOTE
  CALL
  WHATSAPP
  EMAIL
  MEETING
}

model Contact {
  id             String       @id @default(cuid())
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  type   ContactType @default(LEAD)
  name   String
  phone  String?
  email  String?
  source String?
  stage  String?

  cases      Case[]
  activities Activity[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([organizationId])
}

model Case {
  id             String       @id @default(cuid())
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  contactId String
  contact   Contact @relation(fields: [contactId], references: [id], onDelete: Cascade)

  title   String?
  status  CaseStatus  @default(NEW)
  purpose CasePurpose @default(PURCHASE)
  amount  Int? // requested loan amount in ILS

  tasks      Task[]
  activities Activity[]
  scenarios  Scenario[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([organizationId])
  @@index([contactId])
}

model Task {
  id             String       @id @default(cuid())
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  caseId String?
  case   Case?   @relation(fields: [caseId], references: [id], onDelete: Cascade)

  assigneeId String?
  assignee   User?   @relation("TaskAssignee", fields: [assigneeId], references: [id], onDelete: SetNull)

  title String
  dueAt DateTime?
  done  Boolean   @default(false)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([organizationId])
  @@index([caseId])
}

model Activity {
  id             String       @id @default(cuid())
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  contactId String?
  contact   Contact? @relation(fields: [contactId], references: [id], onDelete: Cascade)

  caseId String?
  case   Case?   @relation(fields: [caseId], references: [id], onDelete: Cascade)

  authorId String?
  author   User?   @relation("ActivityAuthor", fields: [authorId], references: [id], onDelete: SetNull)

  channel ActivityChannel @default(NOTE)
  body    String

  createdAt DateTime @default(now())

  @@index([organizationId])
  @@index([contactId])
  @@index([caseId])
}

// A saved mortgage mix (תמהיל) attached to a case. Legs hold the per-track
// allocation: [{ type, pct, rate }]. Inputs + computed totals are snapshotted.
model Scenario {
  id             String       @id @default(cuid())
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  caseId String
  case   Case   @relation(fields: [caseId], references: [id], onDelete: Cascade)

  label        String?
  amount       Int
  termMonths   Int
  cpi          Float
  firstPayment Int
  totalPaid    Int
  feasible     Boolean
  legs         Json

  createdAt DateTime @default(now())

  @@index([organizationId])
  @@index([caseId])
}

// ---------------------------------------------------------------------------
// Financial-data center (global reference data — not tenant-scoped)
// Series: BOI_RATE, CPI_INDEX, CPI_YOY. Synced from BOI Edge API + CBS.
// ---------------------------------------------------------------------------

model MarketReading {
  id        String   @id @default(cuid())
  series    String
  date      DateTime
  value     Float
  createdAt DateTime @default(now())

  @@unique([series, date])
  @@index([series])
}
