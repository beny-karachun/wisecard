# PostgreSQL connection string.
# Free options: Neon (neon.tech) or Supabase (supabase.com). Or a local Postgres.
DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/wisecard?schema=public"

# Auth.js secret. Generate one with:  npx auth secret
# (or: openssl rand -base64 32)
AUTH_SECRET="replace-with-a-long-random-string"

# Protects the market-data sync route (/api/cron/sync). Point a daily cron at
# that URL with header "Authorization: Bearer <secret>" or ?token=<secret>.
CRON_SECRET="replace-with-a-random-string"
